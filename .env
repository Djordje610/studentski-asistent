# Kopiraj u .env i po potrebi promeni vrednosti.

# JWT za oba servisa (dugacak string, obavezno promeniti u produkciji)
JWT_SECRET=mikroservisni-jwt-tajni-kljuc-mora-biti-dovoljno-dug-za-hs256-algoritam-bezbednosti

# Mora biti IDENTICAN u auth-service i studentski-api
INTERNAL_SERVICE_TOKEN=studentski-s2s-internal-token-promeni-u-produkciji

# Host port za studentski-api (u kontejneru je 8080)
STUDENTSKI_API_HOST_PORT=18080

# Opcionalno: pgAdmin kredencijali
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
